{
  "expo": {
    "name": "Notes",
    "slug": "Notes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/notes-icon.png",
    "scheme": "notes",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.arne.notes",
      "queries": {
        "package": [
          "com.openai.chatgpt"
        ]
      },
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/notes-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2ace0c9b-26d7-4f6f-858f-a6f92e515a24"
      }
    }
  }
}
